{
  "name": "kora-apparel-backend",
  "version": "1.0.0",
  "description": "Kora Apparel E-Commerce Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seedAdmin.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:coverage": "jest --forceExit --detectOpenHandles --coverage"
  },
  "dependencies": {
    "@imagekit/nodejs": "^7.3.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.1.0",
    "imagekit": "^6.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "kora-apparel": "file:..",
    "mongoose": "^8.2.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.3",
    "pm2": "^6.0.14",
    "razorpay": "^2.9.2",
    "sharp": "^0.33.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "mongodb-memory-server": "^10.4.3",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/tests/setup.js"
    ],
    "testTimeout": 30000,
    "verbose": true
  }
}
